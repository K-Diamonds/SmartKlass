NEXT_PUBLIC_API_URL=https://smart-klass-api.vercel.app
NEXT_PUBLIC_APP_URL=https://smart-klass.vercel.app
CORS_ALLOW_ORIGINS=https://smart-klass.vercel.app,http://localhost:3000
