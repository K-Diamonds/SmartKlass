{
  "$schema": "./env.manifest.schema.json",
  "description": "Maps SmartKlass env keys to GitHub Actions secrets vs variables (production).",
  "sources": [".env.example", ".env"],
  "overrideFile": ".github/env.production.local",
  "productionDefaults": {
    "VERCEL_PROJECT_ID": "prj_NlfWX4wo1cKv5GcgBAUxLBvh9slO",
    "VERCEL_WEB_PROJECT_ID": "prj_bkyKMYoEJgneQmLikpP1AgA6VwBc",
    "NODE_ENV": "production",
    "WORKER_ENABLED": "false",
    "API_URL": "https://smart-klass-api.vercel.app",
    "NEXT_PUBLIC_API_URL": "https://smart-klass-api.vercel.app",
    "NEXT_PUBLIC_APP_URL": "https://smart-klass.vercel.app",
    "CORS_ALLOW_ORIGINS": "https://smart-klass.vercel.app,http://localhost:3000"
  },
  "localOnly": [
    "MYSQL_ROOT_PASSWORD",
    "MYSQL_DATABASE",
    "MYSQL_USER",
    "MYSQL_PASSWORD"
  ],
  "secrets": [
    "DATABASE_URL",
    "JWT_SECRET",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "REDIS_URL"
  ],
  "deploySecrets": ["VERCEL_TOKEN", "VERCEL_ORG_ID", "VERCEL_PROJECT_ID", "VERCEL_WEB_PROJECT_ID"],
  "variables": [
    "NODE_ENV",
    "API_PORT",
    "API_URL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "JWT_EXPIRES_IN",
    "JWT_REFRESH_EXPIRES_IN",
    "WORKER_ENABLED",
    "OUTBOX_POLL_MS",
    "DAILY_JOB_POLL_MS",
    "DAILY_JOB_HOUR_UTC",
    "CORS_ALLOW_ORIGINS",
    "STAFF_USER_IDS",
    "STAFF_EMAILS",
    "ADMIN_ROLE_ASSIGNMENTS",
    "ADMIN_RATE_LIMIT_MAX",
    "ADMIN_RATE_LIMIT_WINDOW_MS"
  ],
  "vercel": {
    "deploySecrets": [
      "DATABASE_URL",
      "JWT_SECRET",
      "STRIPE_SECRET_KEY",
      "STRIPE_WEBHOOK_SECRET",
      "REDIS_URL",
      "VERCEL_TOKEN",
      "VERCEL_ORG_ID",
      "VERCEL_PROJECT_ID"
    ],
    "deployVariables": [
      "NODE_ENV",
      "API_URL",
      "NEXT_PUBLIC_APP_URL",
      "NEXT_PUBLIC_API_URL",
      "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
      "JWT_EXPIRES_IN",
      "JWT_REFRESH_EXPIRES_IN",
      "WORKER_ENABLED",
      "CORS_ALLOW_ORIGINS",
      "STAFF_USER_IDS",
      "STAFF_EMAILS",
      "ADMIN_ROLE_ASSIGNMENTS",
      "ADMIN_RATE_LIMIT_MAX",
      "ADMIN_RATE_LIMIT_WINDOW_MS"
    ]
  },
  "vercelWeb": {
    "deployVariables": [
      "NODE_ENV",
      "NEXT_PUBLIC_APP_URL",
      "NEXT_PUBLIC_API_URL",
      "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY"
    ]
  }
}
