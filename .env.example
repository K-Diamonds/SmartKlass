# =============================================================================
# SmartKlass Environment Configuration
# Copy this file to .env and adjust values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (MySQL)
# -----------------------------------------------------------------------------
DATABASE_URL="mysql://smartklass:smartklass@localhost:3306/smartklass"

MYSQL_ROOT_PASSWORD=smartklass_root
MYSQL_DATABASE=smartklass
MYSQL_USER=smartklass
MYSQL_PASSWORD=smartklass

# -----------------------------------------------------------------------------
# API (NestJS)
# -----------------------------------------------------------------------------
API_PORT=4000
API_URL=http://localhost:4000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Web (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Auth & Payments
# -----------------------------------------------------------------------------
# JWT_SECRET=your-secret-at-least-32-chars-in-production
JWT_SECRET=dev-only-change-me-use-32-chars-min-in-prod
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Stripe — required for checkout, Connect payouts, and webhooks.
# Get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Admin / Risk (internal staff APIs)
# -----------------------------------------------------------------------------
# Comma-separated allowlist for /admin routes (at least one recommended in prod).
# STAFF_USER_IDS=
# STAFF_EMAILS=ops@yourcompany.com
# Non-allowlist staff roles: email:ROLE or userId:ROLE (FINANCE, RISK_ANALYST, SUPPORT, READ_ONLY)
# ADMIN_ROLE_ASSIGNMENTS=finance@company.com:FINANCE,risk@company.com:RISK_ANALYST
# ADMIN_RATE_LIMIT_MAX=120
# ADMIN_RATE_LIMIT_WINDOW_MS=60000

# Redis — optional; admin rate limiting uses in-memory fallback when unset.
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Workers (outbox processor + daily jobs)
# -----------------------------------------------------------------------------
# WORKER_ENABLED=true
# OUTBOX_POLL_MS=5000
# DAILY_JOB_POLL_MS=60000
# DAILY_JOB_HOUR_UTC=6

# -----------------------------------------------------------------------------
# External Services (placeholders)
# -----------------------------------------------------------------------------
# YOUTUBE_API_KEY=
