# =============================================================================
# SmartKlass Environment Configuration
# Copy this file to .env and adjust values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (MySQL)
# -----------------------------------------------------------------------------
DATABASE_URL="mysql://smartklass:smartklass@localhost:3306/smartklass"

MYSQL_ROOT_PASSWORD=smartklass_root
MYSQL_DATABASE=smartklass
MYSQL_USER=smartklass
MYSQL_PASSWORD=smartklass

# -----------------------------------------------------------------------------
# API (NestJS)
# -----------------------------------------------------------------------------
API_PORT=4000
API_URL=http://localhost:4000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Web (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Auth & Payments
# -----------------------------------------------------------------------------
# JWT_SECRET=your-secret-at-least-32-chars-in-production
JWT_SECRET=dev-only-change-me-use-32-chars-min-in-prod
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Stripe — required for checkout, Connect payouts, and webhooks.
# Get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# External Services (placeholders)
# -----------------------------------------------------------------------------
# YOUTUBE_API_KEY=
